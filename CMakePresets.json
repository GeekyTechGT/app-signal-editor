{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 25,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "windows-mingw64-base",
            "hidden": true,
            "inherits": "base",
            "generator": "Ninja",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            },
            "cacheVariables": {
                "CMAKE_C_COMPILER": "C:/eng_apps/msys64/mingw64/bin/gcc.exe",
                "CMAKE_CXX_COMPILER": "C:/eng_apps/msys64/mingw64/bin/g++.exe",
                "CMAKE_MAKE_PROGRAM": "C:/eng_apps/msys64/mingw64/bin/ninja.exe",
                "CMAKE_PREFIX_PATH": "C:/eng_apps/Qt/6.10.1/mingw_64"
            },
            "environment": {
                "PATH": "C:/eng_apps/msys64/mingw64/bin;$penv{PATH}"
            }
        },
        {
            "name": "linux-gcc-base",
            "hidden": true,
            "inherits": "base",
            "generator": "Ninja",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            },
            "cacheVariables": {
                "CMAKE_C_COMPILER": "gcc",
                "CMAKE_CXX_COMPILER": "g++"
            }
        },
        {
            "name": "docker-gcc-base",
            "hidden": true,
            "inherits": "base",
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "gcc",
                "CMAKE_CXX_COMPILER": "g++",
                "SIGNAL_EDITOR_BUILD_TESTS": "ON",
                "SIGNAL_EDITOR_BUILD_GUI": "OFF",
                "SIGNAL_EDITOR_BUILD_SHARED": "OFF"
            }
        },
        {
            "name": "windows-mingw64-debug",
            "displayName": "Windows MinGW64 Debug",
            "inherits": "windows-mingw64-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "SIGNAL_EDITOR_BUILD_TESTS": "ON",
                "SIGNAL_EDITOR_BUILD_GUI": "ON",
                "SIGNAL_EDITOR_BUILD_SHARED": "ON",
                "SIGNAL_EDITOR_ENABLE_SANITIZERS": "OFF"
            }
        },
        {
            "name": "windows-mingw64-release",
            "displayName": "Windows MinGW64 Release",
            "inherits": "windows-mingw64-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "SIGNAL_EDITOR_BUILD_TESTS": "ON",
                "SIGNAL_EDITOR_BUILD_GUI": "ON",
                "SIGNAL_EDITOR_BUILD_SHARED": "ON",
                "SIGNAL_EDITOR_ENABLE_SANITIZERS": "OFF"
            }
        },
        {
            "name": "linux-gcc-debug",
            "displayName": "Linux GCC Debug",
            "inherits": "linux-gcc-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "SIGNAL_EDITOR_BUILD_TESTS": "ON",
                "SIGNAL_EDITOR_BUILD_GUI": "OFF",
                "SIGNAL_EDITOR_BUILD_SHARED": "ON",
                "SIGNAL_EDITOR_ENABLE_SANITIZERS": "ON"
            }
        },
        {
            "name": "linux-gcc-release",
            "displayName": "Linux GCC Release",
            "inherits": "linux-gcc-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "SIGNAL_EDITOR_BUILD_TESTS": "ON",
                "SIGNAL_EDITOR_BUILD_GUI": "OFF",
                "SIGNAL_EDITOR_BUILD_SHARED": "ON",
                "SIGNAL_EDITOR_ENABLE_SANITIZERS": "OFF"
            }
        },
        {
            "name": "docker-gcc-debug",
            "displayName": "Docker GCC Debug",
            "inherits": "docker-gcc-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "SIGNAL_EDITOR_BUILD_TESTS": "ON",
                "SIGNAL_EDITOR_BUILD_GUI": "OFF",
                "SIGNAL_EDITOR_BUILD_SHARED": "OFF",
                "SIGNAL_EDITOR_ENABLE_SANITIZERS": "ON"
            }
        },
        {
            "name": "docker-gcc-release",
            "displayName": "Docker GCC Release",
            "inherits": "docker-gcc-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "SIGNAL_EDITOR_BUILD_TESTS": "ON",
                "SIGNAL_EDITOR_BUILD_GUI": "OFF",
                "SIGNAL_EDITOR_BUILD_SHARED": "OFF",
                "SIGNAL_EDITOR_ENABLE_SANITIZERS": "OFF"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "windows-mingw64-debug",
            "configurePreset": "windows-mingw64-debug"
        },
        {
            "name": "windows-mingw64-release",
            "configurePreset": "windows-mingw64-release"
        },
        {
            "name": "linux-gcc-debug",
            "configurePreset": "linux-gcc-debug"
        },
        {
            "name": "linux-gcc-release",
            "configurePreset": "linux-gcc-release"
        },
        {
            "name": "docker-gcc-debug",
            "configurePreset": "docker-gcc-debug"
        },
        {
            "name": "docker-gcc-release",
            "configurePreset": "docker-gcc-release"
        }
    ],
    "testPresets": [
        {
            "name": "windows-mingw64-debug",
            "configurePreset": "windows-mingw64-debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "windows-mingw64-release",
            "configurePreset": "windows-mingw64-release",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "linux-gcc-debug",
            "configurePreset": "linux-gcc-debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "linux-gcc-release",
            "configurePreset": "linux-gcc-release",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "docker-gcc-debug",
            "configurePreset": "docker-gcc-debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "docker-gcc-release",
            "configurePreset": "docker-gcc-release",
            "output": {
                "outputOnFailure": true
            }
        }
    ]
}

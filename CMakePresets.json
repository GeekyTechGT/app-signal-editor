{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 25,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "windows-mingw64-base",
            "hidden": true,
            "inherits": "base",
            "generator": "Ninja",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            },
            "cacheVariables": {
                "CMAKE_C_COMPILER":   "C:/eng_apps/msys64/mingw64/bin/gcc.exe",
                "CMAKE_CXX_COMPILER": "C:/eng_apps/msys64/mingw64/bin/g++.exe",
                "CMAKE_MAKE_PROGRAM": "C:/eng_apps/msys64/mingw64/bin/ninja.exe"
            },
            "environment": {
                "PATH": "C:/eng_apps/msys64/mingw64/bin;$penv{PATH}"
            }
        },
        {
            "name": "windows-mingw64-debug",
            "displayName": "Windows MinGW64 GCC Debug",
            "inherits": "windows-mingw64-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE":          "Debug",
                "MYPRJ_BUILD_TESTS":         "ON",
                "MYPRJ_BUILD_GUI":           "ON",
                "MYPRJ_BUILD_SHARED":        "ON",
                "CMAKE_PREFIX_PATH":         "C:/eng_apps/Qt/6.10.1/mingw_64",
                "MYPRJ_ENABLE_SANITIZERS":   "OFF"
            }
        },
        {
            "name": "windows-mingw64-release",
            "displayName": "Windows MinGW64 GCC Release",
            "inherits": "windows-mingw64-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE":          "Release",
                "MYPRJ_BUILD_TESTS":         "ON",
                "MYPRJ_BUILD_GUI":           "ON",
                "MYPRJ_BUILD_SHARED":        "ON",
                "CMAKE_PREFIX_PATH":         "C:/eng_apps/Qt/6.10.1/mingw_64",
                "MYPRJ_ENABLE_SANITIZERS":   "OFF"
            }
        },
        {
            "name": "linux-gcc-base",
            "hidden": true,
            "inherits": "base",
            "generator": "Ninja",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            },
            "cacheVariables": {
                "CMAKE_C_COMPILER":   "gcc",
                "CMAKE_CXX_COMPILER": "g++"
            }
        },
        {
            "name": "linux-gcc-debug",
            "displayName": "Linux GCC Debug",
            "inherits": "linux-gcc-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE":        "Debug",
                "MYPRJ_BUILD_TESTS":       "ON",
                "MYPRJ_BUILD_GUI":         "OFF",
                "MYPRJ_BUILD_SHARED":      "ON",
                "MYPRJ_ENABLE_SANITIZERS": "ON"
            }
        },
        {
            "name": "linux-gcc-release",
            "displayName": "Linux GCC Release",
            "inherits": "linux-gcc-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE":        "Release",
                "MYPRJ_BUILD_TESTS":       "ON",
                "MYPRJ_BUILD_GUI":         "OFF",
                "MYPRJ_BUILD_SHARED":      "ON",
                "MYPRJ_ENABLE_SANITIZERS": "OFF"
            }
        }
    ],
    "buildPresets": [
        { "name": "windows-mingw64-debug",   "configurePreset": "windows-mingw64-debug" },
        { "name": "windows-mingw64-release",  "configurePreset": "windows-mingw64-release" },
        { "name": "linux-gcc-debug",          "configurePreset": "linux-gcc-debug" },
        { "name": "linux-gcc-release",        "configurePreset": "linux-gcc-release" }
    ],
    "testPresets": [
        { "name": "windows-mingw64-debug",   "configurePreset": "windows-mingw64-debug",  "output": {"outputOnFailure": true} },
        { "name": "windows-mingw64-release",  "configurePreset": "windows-mingw64-release", "output": {"outputOnFailure": true} },
        { "name": "linux-gcc-debug",          "configurePreset": "linux-gcc-debug",         "output": {"outputOnFailure": true} },
        { "name": "linux-gcc-release",        "configurePreset": "linux-gcc-release",        "output": {"outputOnFailure": true} }
    ]
}
